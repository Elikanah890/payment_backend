DB_PASSWORD=Postgress321

# ============================================
# REDIS (Caching & Jobs)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_ACCESS_SECRET=blessing_hope_access_secret_key_2026
JWT_REFRESH_SECRET=blessing_hope_refresh_secret_key_2026
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# OTP SETTINGS
# ============================================
OTP_LENGTH=6
OTP_EXPIRY=300
OTP_MAX_ATTEMPTS=3

# ============================================
# PAYMENT GATEWAY (Selcom)
# ============================================
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_BASE_URL=https://api.selcom.co.tz
SELCOM_WEBHOOK_SECRET=

# ============================================
# SMS PROVIDER (Beem Africa)
# ============================================
BEEM_API_KEY=
BEEM_API_SECRET=
BEEM_SENDER_ID=BlessingHope
BEEM_BASE_URL=https://api.beem.africa

# ============================================
# AWS S3 (Receipts Storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=blessing-hope-receipts
AWS_REGION=us-east-1
AWS_S3_URL_EXPIRY=3600

# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
PARENT_URL=http://localhost:3002

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_2FA=false
ENABLE_BULK_IMPORT=true
ENABLE_EXPORT_REPORTS=true
