{
  "name": "blessing-hope-backend",
  "version": "1.0.0",
  "description": "Blessing Hope School Payment System Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=512' nodemon --exec ts-node --files src/server.ts",
    "build": "npx prisma generate && npx tsc --skipLibCheck",
    "start": "node -r dotenv/config dist/server.js",
    "postinstall": "npx prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "pdfkit": "^0.19.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}