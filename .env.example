# ============================================
# DATABASE (Supabase)
# ============================================
DATABASE_URL="postgresql://postgres:[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ============================================
# REDIS (optional — only if you need background jobs)
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_ACCESS_SECRET=change_me_to_random_64_chars
JWT_REFRESH_SECRET=change_me_to_random_64_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# PAYMENT GATEWAY (Selcom) - Optional
# ============================================
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_BASE_URL=https://api.selcom.co.tz
SELCOM_WEBHOOK_SECRET=

# ============================================
# SMS PROVIDER (Beem Africa) - Optional
# ============================================
BEEM_API_KEY=
BEEM_API_SECRET=
BEEM_SENDER_ID=BlessingHope
BEEM_BASE_URL=https://api.beem.africa

# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
APP_URL=https://your-backend.onrender.com
ADMIN_URL=https://your-frontend.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
